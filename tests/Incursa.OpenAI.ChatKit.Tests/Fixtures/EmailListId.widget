{
  "version": "1.0",
  "name": "EmailList",
  "template": "{\"type\":\"ListView\",\"status\":{\"text\":{{ (((emails | length) ~ \" email\" ~ (\"\" if (emails | length) == 1 else \"s\") ~ \" found\")) | tojson }}},\"children\":[{%- set _c -%}{%-for item in emails -%},{\"type\":\"ListViewItem\",\"key\":{{ (item.id) | tojson }},\"gap\":2,\"onClickAction\":{\"type\":\"mail.view_details\",\"payload\":{\"messageId\":{{ (item.id) | tojson }},\"threadId\":{{ (item.threadId) | tojson }},\"mailboxId\":{{ (item.mailboxId) | tojson }}},\"loadingBehavior\":\"self\"},\"children\":[{\"type\":\"Card\",\"size\":\"sm\",\"children\":[{\"type\":\"Col\",\"gap\":2,\"children\":[{\"type\":\"Row\",\"gap\":3,\"align\":\"center\",\"children\":[{\"type\":\"Col\",\"children\":[{\"type\":\"Title\",\"value\":{{ (item.subject or \"(No subject)\") | tojson }},\"size\":\"sm\",\"maxLines\":1},{\"type\":\"Text\",\"value\":{{ (item.id) | tojson }},\"size\":\"sm\",\"maxLines\":1,\"color\":\"secondary\"}]}]},{\"type\":\"Divider\"},{\"type\":\"Col\",\"gap\":1,\"children\":[{%- set _c -%},{\"type\":\"Row\",\"children\":[{\"type\":\"Caption\",\"value\":\"From\",\"color\":\"secondary\"},{\"type\":\"Spacer\"},{\"type\":\"Text\",\"value\":{{ (item.from) | tojson }},\"size\":\"sm\",\"textAlign\":\"end\",\"maxLines\":1}]},{\"type\":\"Row\",\"children\":[{\"type\":\"Caption\",\"value\":\"To\",\"color\":\"secondary\"},{\"type\":\"Spacer\"},{\"type\":\"Text\",\"value\":{{ ((none)) | tojson }},\"size\":\"sm\",\"textAlign\":\"end\",\"maxLines\":1}]}{%-if (item.cc and ((item.cc | length) > 0)) -%},{\"type\":\"Row\",\"children\":[{\"type\":\"Caption\",\"value\":\"Cc\",\"color\":\"secondary\"},{\"type\":\"Spacer\"},{\"type\":\"Text\",\"value\":{{ ((none)) | tojson }},\"size\":\"sm\",\"textAlign\":\"end\",\"maxLines\":1}]}{%-else-%}{%-endif-%}{%-if (item.bcc and ((item.bcc | length) > 0)) -%},{\"type\":\"Row\",\"children\":[{\"type\":\"Caption\",\"value\":\"Bcc\",\"color\":\"secondary\"},{\"type\":\"Spacer\"},{\"type\":\"Text\",\"value\":{{ ((none)) | tojson }},\"size\":\"sm\",\"textAlign\":\"end\",\"maxLines\":1}]}{%-else-%}{%-endif-%}{%- endset -%}{{- (_c[1:] if _c and _c[0] == ',' else _c) -}}]},{\"type\":\"Divider\"},{\"type\":\"Text\",\"value\":{{ (item.preview or \"No preview available.\") | tojson }},\"size\":\"sm\",\"color\":\"secondary\",\"maxLines\":3}]}]}]}{%-endfor-%}{%- endset -%}{{- (_c[1:] if _c and _c[0] == ',' else _c) -}}]}",
  "jsonSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "emails": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "threadId": {
              "type": "string"
            },
            "mailboxId": {
              "type": "string"
            },
            "from": {
              "type": "string"
            },
            "to": {
              "minItems": 1,
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "cc": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "bcc": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "subject": {
              "type": "string"
            },
            "preview": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "from",
            "to",
            "subject",
            "preview"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "emails"
    ],
    "additionalProperties": false
  },
  "outputJsonPreview": {
    "type": "ListView",
    "status": {
      "text": "3 emails found"
    },
    "children": [
      {
        "type": "ListViewItem",
        "key": "eml_001",
        "gap": 2,
        "onClickAction": {
          "type": "mail.view_details",
          "payload": {
            "messageId": "eml_001",
            "threadId": "eml_001",
            "mailboxId": "eml_001"
          },
          "loadingBehavior": "self"
        },
        "children": [
          {
            "type": "Card",
            "size": "sm",
            "children": [
              {
                "type": "Col",
                "gap": 2,
                "children": [
                  {
                    "type": "Row",
                    "gap": 3,
                    "align": "center",
                    "children": [
                      {
                        "type": "Col",
                        "children": [
                          {
                            "type": "Title",
                            "value": "Quarterly update and next steps for 2026 planning",
                            "size": "sm",
                            "maxLines": 1
                          },
                          {
                            "type": "Text",
                            "value": "eml_001",
                            "size": "sm",
                            "maxLines": 1,
                            "color": "secondary"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Divider"
                  },
                  {
                    "type": "Col",
                    "gap": 1,
                    "children": [
                      {
                        "type": "Row",
                        "children": [
                          {
                            "type": "Caption",
                            "value": "From",
                            "color": "secondary"
                          },
                          {
                            "type": "Spacer"
                          },
                          {
                            "type": "Text",
                            "value": "alice@example.com",
                            "size": "sm",
                            "textAlign": "end",
                            "maxLines": 1
                          }
                        ]
                      },
                      {
                        "type": "Row",
                        "children": [
                          {
                            "type": "Caption",
                            "value": "To",
                            "color": "secondary"
                          },
                          {
                            "type": "Spacer"
                          },
                          {
                            "type": "Text",
                            "value": "you@company.com, me@company.com",
                            "size": "sm",
                            "textAlign": "end",
                            "maxLines": 1
                          }
                        ]
                      },
                      {
                        "type": "Row",
                        "children": [
                          {
                            "type": "Caption",
                            "value": "Cc",
                            "color": "secondary"
                          },
                          {
                            "type": "Spacer"
                          },
                          {
                            "type": "Text",
                            "value": "bob@example.com",
                            "size": "sm",
                            "textAlign": "end",
                            "maxLines": 1
