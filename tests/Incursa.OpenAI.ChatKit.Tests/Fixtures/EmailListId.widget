                  {
                    "type": "Text",
                    "value": "Hi team, here's the Q1 summary and the key actions for next week...",
                    "size": "sm",
                    "color": "secondary",
                    "maxLines": 3
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "type": "ListViewItem",
        "key": "eml_002",
