{
  "version": "1.0",
  "name": "Email Summary",
  "template": "{\"type\":\"Card\",\"size\":\"sm\",\"children\":[{\"type\":\"Col\",\"gap\":2,\"children\":[{\"type\":\"Row\",\"gap\":3,\"align\":\"center\",\"children\":[{\"type\":\"Title\",\"value\":{{ (subject) | tojson }},\"size\":\"sm\",\"maxLines\":1}]},{\"type\":\"Divider\"},{\"type\":\"Col\",\"gap\":1,\"children\":[{%- set _c -%},{\"type\":\"Row\",\"children\":[{\"type\":\"Caption\",\"value\":\"From\",\"color\":\"secondary\"},{\"type\":\"Spacer\"},{\"type\":\"Text\",\"value\":{{ (from) | tojson }},\"size\":\"sm\",\"textAlign\":\"end\",\"maxLines\":1}]},{\"type\":\"Row\",\"children\":[{\"type\":\"Caption\",\"value\":\"To\",\"color\":\"secondary\"},{\"type\":\"Spacer\"},{\"type\":\"Text\",\"value\":{{ ((none)) | tojson }},\"size\":\"sm\",\"textAlign\":\"end\",\"maxLines\":1}]}{%-if (cc and ((cc | length) > 0)) -%},{\"type\":\"Row\",\"children\":[{\"type\":\"Caption\",\"value\":\"Cc\",\"color\":\"secondary\"},{\"type\":\"Spacer\"},{\"type\":\"Text\",\"value\":{{ ((none)) | tojson }},\"size\":\"sm\",\"textAlign\":\"end\",\"maxLines\":1}]}{%-else-%}{%-endif-%}{%-if (bcc and ((bcc | length) > 0)) -%},{\"type\":\"Row\",\"children\":[{\"type\":\"Caption\",\"value\":\"Bcc\",\"color\":\"secondary\"},{\"type\":\"Spacer\"},{\"type\":\"Text\",\"value\":{{ ((none)) | tojson }},\"size\":\"sm\",\"textAlign\":\"end\",\"maxLines\":1}]}{%-else-%}{%-endif-%}{%- endset -%}{{- (_c[1:] if _c and _c[0] == ',' else _c) -}}]},{\"type\":\"Divider\"},{\"type\":\"Text\",\"value\":{{ (preview) | tojson }},\"size\":\"sm\",\"color\":\"secondary\",\"maxLines\":3}]}]}",
  "jsonSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "from": {
        "type": "string"
      },
      "to": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "cc": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "bcc": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "subject": {
        "type": "string"
      },
      "preview": {
        "type": "string"
      }
    },
    "required": [
      "from",
      "to",
      "subject",
      "preview"
    ],
    "additionalProperties": false
  },
  "outputJsonPreview": {
    "type": "Card",
    "size": "sm",
    "children": [
      {
        "type": "Col",
        "gap": 2,
        "children": [
          {
            "type": "Row",
            "gap": 3,
            "align": "center",
            "children": [
              {
                "type": "Title",
                "value": "Upcoming computing symposium invitation and logistics",
                "size": "sm",
                "maxLines": 1
              }
            ]
          },
          {
            "type": "Divider"
          },
          {
            "type": "Col",
            "gap": 1,
            "children": [
              {
                "type": "Row",
                "children": [
                  {
                    "type": "Caption",
                    "value": "From",
                    "color": "secondary"
                  },
                  {
                    "type": "Spacer"
                  },
                  {
                    "type": "Text",
                    "value": "Ada Lovelace <ada@analysis.co>",
                    "size": "sm",
                    "textAlign": "end",
                    "maxLines": 1
                  }
                ]
              },
              {
                "type": "Row",
                "children": [
                  {
                    "type": "Caption",
                    "value": "To",
                    "color": "secondary"
                  },
                  {
                    "type": "Spacer"
                  },
                  {
                    "type": "Text",
                    "value": "Grace Hopper <grace@navy.mil>, Alan Turing <alan@bletchley.uk>",
                    "size": "sm",
                    "textAlign": "end",
                    "maxLines": 1
                  }
                ]
              },
              {
                "type": "Row",
                "children": [
                  {
                    "type": "Caption",
                    "value": "Cc",
                    "color": "secondary"
                  },
                  {
                    "type": "Spacer"
                  },
                  {
                    "type": "Text",
                    "value": "Charles Babbage <charles@analytical.org>",
                    "size": "sm",
                    "textAlign": "end",
                    "maxLines": 1
                  }
                ]
              }
            ]
          },
          {
            "type": "Divider"
          },
          {
            "type": "Text",
            "value": "Hi Grace — sharing travel details and draft agenda. Please review and let me know if the 10:30 slot works.",
            "size": "sm",
            "color": "secondary",
            "maxLines": 3
          }
        ]
      }
    ]
  },
